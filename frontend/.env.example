# Backend API base URL
# Development (running locally): http://localhost:8000
# Docker Compose: leave empty — nginx proxies /api/* to the backend container
VITE_API_URL=http://localhost:8000

# Giphy API key for GIF picker (Phase 6)
# Get a free key at: https://developers.giphy.com/
VITE_GIPHY_API_KEY=
