# Copy to .env and fill in your values
# Used by docker-compose.yml

ANTHROPIC_API_KEY=sk-ant-...

# Scheduler settings
SCHEDULER_TIMEZONE=Australia/Sydney
SCHEDULER_HOUR=8
SCHEDULER_MINUTE=0

# AI provider: "auto" | "claude" | "openai" | "gemini" | "local"
AI_PROVIDER=auto

# OpenAI (used when AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (used when AI_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Local AI / LM Studio / Ollama (used when AI_PROVIDER=local or auto)
LOCAL_AI_URL=http://localhost:1234/v1
LOCAL_AI_MODEL=
